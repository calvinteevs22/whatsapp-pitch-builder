# Database (MySQL 8.0+)
DATABASE_URL="mysql://user:password@localhost:3306/wa_thread_builder"

# Auth - JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET="your-strong-random-secret-here"

# App Identity
VITE_APP_ID="wa-thread-builder"
OWNER_OPEN_ID="admin-user-id"
OWNER_NAME="Your Name"

# LLM (OpenAI-compatible API)
# Option 1: OpenAI
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_BASE_URL="https://api.openai.com"
LLM_MODEL="gpt-4o"
LLM_MAX_TOKENS="16384"

# Option 2: Use BUILT_IN_FORGE_API_* if you prefer (legacy naming)
# BUILT_IN_FORGE_API_URL="https://api.openai.com"
# BUILT_IN_FORGE_API_KEY="sk-your-key"

# Frontend LLM (for client-side features, if any)
# VITE_FRONTEND_FORGE_API_URL="https://api.openai.com"
# VITE_FRONTEND_FORGE_API_KEY="sk-your-frontend-key"

# S3 Storage (optional - falls back to local ./uploads/ directory)
# S3_REGION="us-east-1"
# S3_BUCKET="wa-thread-builder"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
# S3_PUBLIC_URL="https://your-bucket.s3.us-east-1.amazonaws.com"
# S3_ENDPOINT="https://account-id.r2.cloudflarestorage.com"  # For Cloudflare R2 or MinIO

# Image Generation (optional - uses OpenAI DALL-E 3)
# OPENAI_API_KEY is reused for image generation if set

# Server
PORT=3000

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_AGENCY="price_..."

# Email (Resend - https://resend.com)
RESEND_API_KEY="re_..."
EMAIL_FROM="WhatsApp Pitch Builder <noreply@yourdomain.com>"

# App URL (used in email links)
APP_URL="https://yourdomain.com"
